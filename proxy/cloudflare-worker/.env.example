# Cloudflare Worker — Error Capture Proxy
# Set these as Cloudflare secrets: wrangler secret put GITHUB_TOKEN

# Required: GitHub Personal Access Token with Issues read/write permission
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Required: Target repository where issues will be created
GITHUB_REPO=myorg/myapp

# Optional: Comma-separated list of allowed origins (empty = allow all in dev)
ALLOWED_ORIGINS=https://myapp.com,https://staging.myapp.com

# Optional: Environment name shown in issue body
ENVIRONMENT=production
